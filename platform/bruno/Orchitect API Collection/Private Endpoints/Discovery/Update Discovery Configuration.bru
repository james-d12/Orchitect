meta {
  name: Update Discovery Configuration
  type: http
  seq: 3
}

put {
  url: {{API_BASE_URL}}/discovery/{{DISCOVERY_CONFIG_ID}}
  body: json
  auth: inherit
}

body:json {
  {
    "organisationId": "{{ORGANISATION_ID}}",
    "isEnabled": false,
    "platformConfig": {
      "includeArchived": "true"
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
